# === Telephony Provider (pick one) ===
TELEPHONY_PROVIDER=twilio  # twilio or telnyx

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...  # Your Twilio number (E.164)

# Telnyx (alternative)
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
TELNYX_PHONE_NUMBER=+1...

# === Speech-to-Text ===
DEEPGRAM_API_KEY=  # $200 free credit at signup

# === Text-to-Speech (pick one) ===
TTS_PROVIDER=cartesia  # cartesia, openai, or xtts
CARTESIA_API_KEY=  # Free tier available
# OPENAI_API_KEY=  # If using OpenAI TTS
# XTTS_SERVER_URL=http://localhost:8004  # If self-hosting Coqui XTTS

# === LLM ===
LLM_PROVIDER=openai  # openai, google, or anthropic
OPENAI_API_KEY=
# GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=

# === Server ===
LOCAL_SERVER_URL=https://your-ngrok-url.ngrok.io  # For Twilio callbacks
PORT=7860
CALLER_LANGUAGE=de  # de or en
